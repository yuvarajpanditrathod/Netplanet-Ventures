</section>

<style>
    /* Custom styles for interactive elements */
    .project-type-btn input:checked + div {
        border-color: #0EA5E9;
        background-color: rgba(14, 165, 233, 0.08);
    }
    
    .project-type-btn input:checked + div i {
        color: #0EA5E9;
    }
    
    .project-type-btn input:checked + div span {
        color: #0EA5E9;
        font-weight: 600;
    }
    
    .contact-method-btn input:checked + div {
        border-color: #0EA5E9;
        background-color: rgba(14, 165, 233, 0.08);
    }
    
    .contact-method-btn input:checked + div .w-5 {
        border-color: #0EA5E9;
    }
    
    .contact-method-btn input:checked + div .w-5 .w-2\.5 {
        display: flex;
    }
    
    .contact-method-btn input:checked + div span {
        color: #0EA5E9;
    }
    
    /* Focus styles */
    input:focus, textarea:focus, select:focus {
        outline: none;
        box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1);
    }
    
    /* Animation for form submission */
    @keyframes formSuccess {
        0% { transform: translateY(10px); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }
    
    #form-response.show {
        display: block;
        animation: formSuccess 0.5s ease-out;
        border-color: #10b981;
        background-color: rgba(16, 185, 129, 0.05);
    }
</style>

<script>
    // Interactive form functionality
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('professional-contact-form');
        const projectTypeBtns = document.querySelectorAll('.project-type-btn');
        const contactMethodBtns = document.querySelectorAll('.contact-method-btn');
        const formResponse = document.getElementById('form-response');
        
        // Project type button selection
        projectTypeBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const input = this.querySelector('input');
                input.checked = !input.checked;
                this.classList.toggle('active');
            });
        });
        
        // Contact method button selection
        contactMethodBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                const input = this.querySelector('input');
                contactMethodBtns.forEach(b => {
                    b.querySelector('input').checked = false;
                });
                input.checked = true;
            });
        });
        
        // Form submission
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // Simple validation
            const requiredFields = form.querySelectorAll('[required]');
            let isValid = true;
            
            requiredFields.forEach(field => {
                if (!field.value.trim()) {
                    field.classList.add('border-red-500');
                    isValid = false;
                } else {
                    field.classList.remove('border-red-500');
                }
            });
            
            if (isValid) {
                // Show success message
                formResponse.classList.remove('hidden');
                formResponse.classList.add('show');
                
                // Reset form after 3 seconds
                setTimeout(() => {
                    form.reset();
                    formResponse.classList.remove('show');
                    setTimeout(() => formResponse.classList.add('hidden'), 300);
                }, 5000);
            }
        });
        
        // Remove error state on input
        form.querySelectorAll('input, textarea, select').forEach(field => {
            field.addEventListener('input', function() {
                if (this.classList.contains('border-red-500')) {
                    this.classList.remove('border-red-500');
                }
            });
        });
    });
</script>